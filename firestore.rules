// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: workspaces
// Fields:
//   - name: string (required)
//   - ownerId: string (required) - UID of creator
//   - members: list (required) - List of UIDs
//
// Collection: workspaces/{workspaceId}/nodes
// Fields:
//   - type: string
//   - position: map {x: number, y: number}
//   - data: map {label: string}
//   - workspaceId: string
//
// Collection: workspaces/{workspaceId}/edges
// Fields:
//   - source: string
//   - target: string
//   - animated: bool
//   - workspaceId: string
//
// Collection: invites
// Fields:
//   - workspaceId: string
//   - createdBy: string
//   - expiresAt: timestamp
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isAuthenticated() &&
        ((exists(userPath) && get(userPath).data.role == 'admin') ||
          (request.auth.token.email == "matheusmain2018@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(data) {
      return isAuthenticated() && request.auth.uid == data.ownerId;
    }
    
    function isMember(data) {
      return isAuthenticated() && (request.auth.uid in data.members || request.auth.uid == data.ownerId || isAdmin());
    }

    function getWorkspace(workspaceId) {
      return get(/databases/$(database)/documents/workspaces/$(workspaceId)).data;
    }

    function isWorkspaceMember(workspaceId) {
      let wsPath = /databases/$(database)/documents/workspaces/$(workspaceId);
      return isAuthenticated() && exists(wsPath) && 
             (request.auth.uid in get(wsPath).data.members || 
              request.auth.uid == get(wsPath).data.ownerId || 
              isAdmin());
    }

    function isValidWorkspace(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.ownerId is string && data.members is list &&
             (data.keys().hasOnly(['name', 'ownerId', 'members', 'createdAt']));
    }

    function isValidNode(data) {
      return true;
    }

    function isValidEdge(data) {
      return data.source is string && data.target is string;
    }

    // Workspaces
    match /workspaces/{workspaceId} {
      allow read: if isMember(resource.data);
      allow create: if isAuthenticated() && isValidWorkspace(request.resource.data) && request.resource.data.ownerId == request.auth.uid;
      allow update: if (isMember(resource.data) && isValidWorkspace(request.resource.data) && request.resource.data.ownerId == resource.data.ownerId) ||
                    (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']) && request.resource.data.members.hasAll(resource.data.members) && request.resource.data.members.hasAll([request.auth.uid]));
      allow delete: if isOwner(resource.data);

      // Subcollections
      match /nodes/{nodeId} {
        allow read: if isWorkspaceMember(workspaceId);
        allow create, update: if isWorkspaceMember(workspaceId) && isValidNode(request.resource.data);
        allow delete: if isWorkspaceMember(workspaceId);
      }

      match /edges/{edgeId} {
        allow read: if isWorkspaceMember(workspaceId);
        allow create, update: if isWorkspaceMember(workspaceId) && isValidEdge(request.resource.data);
        allow delete: if isWorkspaceMember(workspaceId);
      }
    }

    // Invites
    match /invites/{inviteId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isWorkspaceMember(request.resource.data.workspaceId);
      allow delete: if isAuthenticated() && isWorkspaceMember(resource.data.workspaceId);
    }

    // User Profiles (for display names)
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }
  }
}
